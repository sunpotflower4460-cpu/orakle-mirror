# === Oracle Mirror — Environment Variables ===
#
# このファイルをコピーして .env.local を作成し、各値を埋めてください。
# .env.local はリポジトリにコミットされません(.gitignore 済)。

# --- BFF (Cloudflare Workers) endpoint ---
# 開発: ローカルで cd bff && npm run dev を起動した場合
# VITE_BACKEND_URL=http://localhost:8787/oracle
# 本番: Cloudflare デプロイ後の URL (人間タスク M-3 で確定)
# VITE_BACKEND_URL=https://oracle-mirror-bff.<subdomain>.workers.dev/oracle
VITE_BACKEND_URL=

# --- Gemini API Key (DEPRECATED / 開発時のみ) ---
# Phase 5-2 完了後、フロント側では Gemini を直接呼ばないため不要。
# Phase 5.5 で完全削除予定。新規環境では設定しないこと。
VITE_GEMINI_API_KEY=

# --- RevenueCat (Phase 6 で利用) ---
VITE_REVENUECAT_IOS_API_KEY=

# --- Legal URLs (Phase 7-2 で利用) ---
VITE_TERMS_URL=
VITE_PRIVACY_URL=
