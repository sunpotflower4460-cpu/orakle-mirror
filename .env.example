# === Oracle Mirror — Environment Variables ===
#
# Copy this file to .env.local and replace every placeholder with real values.
# Do not commit .env.local.
# These VITE_* values are bundled into the client app. Do not put server secrets here.

# --- BFF (Cloudflare Workers) endpoint ---
# Required for App Store readiness. Use the deployed BFF /oracle endpoint.
VITE_BACKEND_URL=

# --- RevenueCat ---
# RevenueCat iOS Public SDK key. This is a client SDK key, not a server secret.
VITE_REVENUECAT_IOS_API_KEY=

# --- Legal URLs ---
# Required for App Store readiness. Use reachable public legal pages.
VITE_TERMS_URL=
VITE_PRIVACY_URL=

# --- Support ---
# App Store readiness requires at least one public support contact path.
VITE_SUPPORT_URL=
VITE_SUPPORT_EMAIL=
