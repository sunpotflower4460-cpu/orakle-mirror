{
  "name": "oracle-mirror",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test:entropy": "node --experimental-strip-types scripts/entropy-selftest.ts",
    "test:keywords": "node --experimental-strip-types scripts/keywords-selftest.ts",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:run": "npm run build && npx cap sync ios && npx cap run ios",
    "deploy:cloudflare": "npx wrangler deploy --config wrangler.toml",
    "deploy:cloudflare:upload": "npx wrangler versions upload --config wrangler.toml",
    "appstore:check": "node scripts/appstore-check.mjs"
  },
  "dependencies": {
    "@capacitor/browser": "^6.0.6",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/keyboard": "^6.0.4",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/share": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@revenuecat/purchases-capacitor": "^9.2.2",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "globals": "17.7.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "8.62.0",
    "vite": "^5.4.11"
  }
}
